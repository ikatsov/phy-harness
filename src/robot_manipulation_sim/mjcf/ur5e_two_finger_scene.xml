<mujoco model="ur5e_two_finger_scene">
  <compiler angle="radian" autolimits="true" strippath="false" boundmass="0.001" boundinertia="0.001"/>

  <option timestep="0.002" integrator="implicitfast" gravity="0 0 -9.81">
    <flag warmstart="enable"/>
  </option>

  <visual>
    <global azimuth="140" elevation="-20"/>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
  </visual>

  <default>
    <default class="scene_object">
      <geom friction="1 0.01 0.001" rgba="0.85 0.55 0.2 1"/>
    </default>
  </default>

  <asset>
    <texture name="grid_tex" type="2d" builtin="checker" width="512" height="512" rgb1="0.1 0.2 0.1" rgb2="0.2 0.3 0.2"/>
    <material name="grid_mat" texture="grid_tex" texrepeat="8 8" reflectance="0.2"/>
  </asset>

  <!-- Universal Robots UR5e meshes/collision from MuJoCo Menagerie (vendored under menagerie_ur5e/). -->
  <include file="menagerie_ur5e/ur5e_robot.xml"/>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light pos="-1 -1 1.2" dir="0.3 0.3 -1" diffuse="0.4 0.4 0.4"/>

    <geom name="floor" type="plane" size="3 3 0.01" material="grid_mat" condim="3"/>

    <camera name="overview" pos="1.1 1.0 0.85" mode="fixed" xyaxes="-0.65 0.76 0 -0.35 -0.30 0.89"/>
    <camera name="topdown" pos="0.38 0 2.35" mode="fixed" xyaxes="1 0 0 0 1 0" fovy="48"/>
    <!-- Side / profile view (-X side of table, looking +X); pairs with overview/topdown/wrist in 2×2 rollout video -->
    <camera name="side_rgb" pos="-1.15 0.38 0.65" mode="fixed" xyaxes="0 -1 0 0 0 -1"/>

    <body name="grasp_box" pos="0.52 0.0 0.035">
      <freejoint name="grasp_box_free"/>
      <site name="box_site" type="sphere" size="0.001" rgba="0 0 0 0"/>
      <inertial pos="0 0 0" mass="0.12" diaginertia="2e-4 2e-4 2e-4"/>
      <geom name="box_geom" type="box" size="0.025 0.04 0.025" class="scene_object"/>
    </body>
  </worldbody>

  <actuator>
    <position name="a_shoulder_pan" joint="shoulder_pan_joint" kp="2000" ctrlrange="-6.28319 6.28319"/>
    <position name="a_shoulder_lift" joint="shoulder_lift_joint" kp="2000" ctrlrange="-6.28319 6.28319"/>
    <position name="a_elbow" joint="elbow_joint" kp="1500" ctrlrange="-3.1415 3.1415"/>
    <position name="a_wrist_1" joint="wrist_1_joint" kp="500" ctrlrange="-6.28319 6.28319"/>
    <position name="a_wrist_2" joint="wrist_2_joint" kp="500" ctrlrange="-6.28319 6.28319"/>
    <position name="a_wrist_3" joint="wrist_3_joint" kp="500" ctrlrange="-6.28319 6.28319"/>
    <general name="a_gripper" tendon="split" forcerange="-5 5" ctrlrange="0 255"
      gainprm="0.3137255 0 0" biasprm="0 -100 -10"/>
  </actuator>

  <sensor>
    <framepos name="box_pos" objtype="body" objname="grasp_box"/>
    <framequat name="box_quat" objtype="body" objname="grasp_box"/>
    <velocimeter name="box_vel" site="box_site"/>
  </sensor>
</mujoco>
