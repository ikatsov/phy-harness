# Copy to `.env` in the repository root (same directory as pyproject.toml), then fill in.
#   cp .env.example .env
#
# Google AI Studio: https://aistudio.google.com/apikey

# Required for scripts/validate_rollout.py (Gemini analyzers) and scripts/robot_manipulation_loop.py (VLM step)
# Loaded from repo root when you `pip install -e ".[vlm]"` (includes python-dotenv).
GEMINI_API_KEY=

# Optional: alternate env name supported by the scripts
# GOOGLE_API_KEY=

# Optional model id (default in code: gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash

# Optional: max evaluated clip size for inline video (default 19 MiB; API limit ~20 MiB)
# GEMINI_INLINE_VIDEO_MAX_MB=19
